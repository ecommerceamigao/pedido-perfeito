const fmt = v => v !== null && !isNaN(v) ? (v*100).toFixed(1)+'%' : '—';
const color = (v, meta) => v===null||meta===null ? 'var(--gray-300)' : v>=meta ? 'var(--green)' : v>=meta-0.05 ? 'var(--yellow)' : 'var(--red)';

function setVal(id, val, clr) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = fmt(val);
  el.style.color = clr || 'inherit';
}

function setBN(valId, badgeId, val, meta) {
  const el = document.getElementById(valId);
  if (el) { el.textContent = fmt(val); }
  const badge = document.getElementById(badgeId);
  if (!badge) return;
  if (val === null) { badge.className='meta-badge'; badge.textContent='Sem dados'; return; }
  if (meta === null) { badge.className='meta-badge'; badge.textContent=''; return; }
  const diff = val - meta;
  if (diff >= 0)       { badge.className='meta-badge above'; badge.textContent=`✅ +${(diff*100).toFixed(1)}pp`; }
  else if (diff>=-0.05){ badge.className='meta-badge near';  badge.textContent=`⚠️ ${(diff*100).toFixed(1)}pp`; }
  else                 { badge.className='meta-badge below'; badge.textContent=`❌ ${(diff*100).toFixed(1)}pp`; }
}

// ══════════════════════════════════════════
//  GAUGE BUILDER — renders full SVG into wrap div
// ══════════════════════════════════════════
const NS = 'http://www.w3.org/2000/svg';

function buildGaugeSVG(prefix) {
  const wrap = document.getElementById(`gwrap-${prefix}`);
  if (!wrap || wrap.querySelector('svg')) return; // already built
  // Bigger viewBox: cx=110, cy=110, r=90
  const svg = document.createElementNS(NS,'svg');
  svg.setAttribute('viewBox','0 0 220 120');
  svg.setAttribute('xmlns', NS);
  svg.style.overflow = 'visible';

  const cx=110, cy=112, r=90, sw=20;
  const arc = Math.PI * r; // half-circle circumference ≈ 282.7

  // helper: create element
  const el = (tag, attrs) => {
    const e = document.createElementNS(NS, tag);
    Object.entries(attrs).forEach(([k,v]) => e.setAttribute(k,v));
    return e;
  };

  const arcPath = `M${cx-r},${cy} A${r},${r} 0 0,1 ${cx+r},${cy}`;

  // Background arc
  svg.appendChild(el('path',{d:arcPath,fill:'none',stroke:'#EDF1F7','stroke-width':sw,'stroke-linecap':'round'}));

  // Color zone arcs
  ['red','yel','grn'].forEach(z => {
    const p = el('path',{id:`${prefix}-${z}`,d:arcPath,fill:'none',
      stroke: z==='red'?'#FCA5A5':z==='yel'?'#FDE68A':'#6EE7B7',
      'stroke-width':sw,'stroke-linecap':'round','stroke-dasharray':`0 ${arc}`});
    svg.appendChild(p);
  });

  // Tick marks at 0, 25, 50, 75, 100%
  [0,25,50,75,100].forEach(pct => {
    const angle = -180 + pct * 1.8; // -180°→0°
    const rad = angle * Math.PI / 180;
    const cos = Math.cos(rad), sin = Math.sin(rad);
    const r1 = r - sw/2 - 2, r2 = r + sw/2 + 2;
    svg.appendChild(el('line',{
      x1: cx + cos*r1, y1: cy + sin*r1,
      x2: cx + cos*r2, y2: cy + sin*r2,
      stroke:'#fff','stroke-width':1.5,'stroke-linecap':'round',opacity:.8
    }));
    // Label
    const lr = r + sw/2 + 14;
    const lx = cx + Math.cos(rad)*lr;
    const ly = cy + Math.sin(rad)*lr;
    const t = el('text',{x:lx,y:ly,'font-size':'11','font-weight':'800',fill:'#3A4A6B',
      'text-anchor':'middle','dominant-baseline':'middle','font-family':'Nunito,sans-serif'});
    t.textContent = pct+'%';
    svg.appendChild(t);
  });

  // Meta marker (red tick) — position set dynamically
  const metamark = el('line',{id:`${prefix}-metamark`,
    x1:cx, y1:cy-r+sw/2+2, x2:cx, y2:cy-r-sw/2-4,
    stroke:'#E53E3E','stroke-width':3,'stroke-linecap':'round',
    transform:`rotate(-90,${cx},${cy})`});
  svg.appendChild(metamark);

  // Meta label
  const metalabel = el('text',{id:`${prefix}-metalabel`,x:cx,y:cy-r-sw/2-14,
    'font-size':'10','font-weight':'800',fill:'#E53E3E','text-anchor':'middle',
    'font-family':'Nunito,sans-serif',transform:`rotate(-90,${cx},${cy})`});
  metalabel.textContent = 'META';
  svg.appendChild(metalabel);

  // Needle shadow
  const needleShadow = el('line',{id:`${prefix}-needleshadow`,
    x1:cx, y1:cy-2, x2:cx, y2:cy-r+sw+8,
    stroke:'rgba(0,0,0,0.12)','stroke-width':6,'stroke-linecap':'round',
    transform:`rotate(-90,${cx},${cy})`});
  svg.appendChild(needleShadow);

  // Needle
  const needle = el('line',{id:`${prefix}-needle`,
    x1:cx, y1:cy-2, x2:cx, y2:cy-r+sw+5,
    stroke:'#3A4A6B','stroke-width':3.5,'stroke-linecap':'round',
    transform:`rotate(-90,${cx},${cy})`});
  svg.appendChild(needle);

  // Hub circle (outer ring)
  svg.appendChild(el('circle',{cx,cy,r:10,fill:'#fff',stroke:'#EDF1F7','stroke-width':3}));
  // Hub inner
  const hub = el('circle',{id:`${prefix}-hub`,cx,cy,r:7,fill:'#3A4A6B'});
  svg.appendChild(hub);

  // Center value text
  const valText = el('text',{id:`${prefix}-val`,x:cx,y:cy-28,
    'font-size':'22','font-weight':'800',fill:'#3A4A6B','text-anchor':'middle',
    'font-family':'Sora,sans-serif'});
  valText.textContent = '—';
  svg.appendChild(valText);

  wrap.appendChild(svg);
}

// Init all 4 gauge SVGs on load
function initGauges() {
  ['gs1p-pp','gs1p-pc','gi3p-pp','gi3p-pc'].forEach(buildGaugeSVG);
}

// ── Update gauge values & animate ──
function updateGauge(prefix, val, meta) {
  const arc = Math.PI * 90; // r=90, half-circle
  const pct  = val  !== null ? Math.min(Math.max(val,  0), 1) : 0;

  // Arc starts at the left (SVG angle = -90° from top = 180° from right).
  // The arc path goes from left (-90°) to right (+90°) in SVG space.
  // rotate(-90) = 0%, rotate(+90) = 100%
  const deg     = -90 + pct  * 180;
  const metaDeg = -90 + meta * 180;

  const fillColor = val === null  ? '#9FB3CC'
    : val >= meta               ? '#00B47E'
    : val >= meta - 0.05        ? '#F6C000'
    :                             '#E53E3E';

  const needleColor = val === null ? '#9FB3CC' : fillColor;
  const cx = 110, cy = 112;

  // Rotate needle + shadow
  ['needle','needleshadow'].forEach(id => {
    const el = document.getElementById(`${prefix}-${id}`);
    if (el) el.setAttribute('transform', `rotate(${deg.toFixed(2)},${cx},${cy})`);
  });

  // Hub color
  const hub = document.getElementById(`${prefix}-hub`);
  if (hub) hub.setAttribute('fill', needleColor);

  // Value text
  const valEl = document.getElementById(`${prefix}-val`);
  if (valEl) {
    valEl.textContent = val !== null ? (val*100).toFixed(1)+'%' : '—';
    valEl.setAttribute('fill', needleColor);
  }

  // Meta marker at correct position
  const metamark  = document.getElementById(`${prefix}-metamark`);
  const metalabel = document.getElementById(`${prefix}-metalabel`);
  if (metamark)  metamark.setAttribute('transform',  `rotate(${metaDeg.toFixed(2)},${cx},${cy})`);
  if (metalabel) metalabel.setAttribute('transform', `rotate(${metaDeg.toFixed(2)},${cx},${cy})`);

  // Color arcs — red: 0→yellowStart, yellow: yellowStart→meta, green: meta→100%
  const yellowStart = Math.max(meta - 0.10, 0);
  const redLen    = yellowStart * arc;
  const yellowLen = (meta - yellowStart) * arc;
  const greenLen  = (1 - meta) * arc;

  const setArcEl = (suffix, dash, offset) => {
    const el = document.getElementById(`${prefix}-${suffix}`);
    if (!el) return;
    el.setAttribute('stroke-dasharray', `${dash.toFixed(2)} ${(arc - dash).toFixed(2)}`);
    el.setAttribute('stroke-dashoffset', (-offset).toFixed(2));
  };
  setArcEl('red', redLen, 0);
  setArcEl('yel', yellowLen, redLen);
  setArcEl('grn', greenLen, redLen + yellowLen);

  // Stat cells
  const statEl = document.getElementById(`${prefix}-stat`);
  if (statEl) {
    statEl.textContent = val !== null ? (val*100).toFixed(1)+'%' : '—';
    statEl.style.color = fillColor;
  }

  const diffEl = document.getElementById(`${prefix}-diff`);
  if (diffEl && val !== null) {
    const d = (val - meta) * 100;
    diffEl.textContent = (d >= 0 ? '+' : '') + d.toFixed(1) + 'pp';
    diffEl.style.color = d >= 0 ? '#00B47E' : '#E53E3E';
    diffEl.style.fontWeight = '800';
  } else if (diffEl) {
    diffEl.textContent = '—';
  }

  // Card border accent color
  const card = document.getElementById(`gcard-${prefix}`);
  if (card) card.style.borderTop = `4px solid ${fillColor}`;
}


<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Pedido Perfeito — Grupo Amigão</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --blue-main:#0057B8;--blue-dark:#003A8C;--blue-mid:#0070D8;--blue-light:#E8F2FF;
    --orange:#F5821F;--orange-light:#FFF3E8;--green:#00B47E;--green-light:#E6F9F4;
    --red:#E53E3E;--red-light:#FEF2F2;--yellow:#F6C000;--teal:#009CA6;--teal-light:#E6F9FA;
    --gray-100:#F7F9FC;--gray-200:#EDF1F7;--gray-300:#D8E0EC;--gray-500:#7B8FB0;--gray-700:#3A4A6B;
    --white:#FFFFFF;
    --shadow-sm:0 2px 8px rgba(0,87,184,0.08);--shadow-md:0 4px 20px rgba(0,87,184,0.12);
    --radius:16px;--radius-sm:10px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Nunito',sans-serif;background:var(--gray-100);color:var(--gray-700);min-height:100vh;}

  /* HEADER */
  .header{background:linear-gradient(135deg,var(--blue-dark) 0%,var(--blue-main) 60%,var(--blue-mid) 100%);
    padding:0 32px;display:flex;align-items:center;justify-content:space-between;
    min-height:80px;position:sticky;top:0;z-index:100;box-shadow:var(--shadow-md);}
  .header-logos{display:flex;align-items:center;gap:24px;}
  .header-logos img{height:52px;object-fit:contain;}
  .logo-divider{width:1px;height:40px;background:rgba(255,255,255,0.3);}
  .header-title{text-align:center;color:white;}
  .header-title .label{font-size:11px;font-weight:700;letter-spacing:3px;text-transform:uppercase;opacity:0.7;}
  .header-title h1{font-family:'Sora',sans-serif;font-size:20px;font-weight:800;}
  .header-date{color:rgba(255,255,255,0.8);font-size:13px;font-weight:600;}

  /* FILTERS */
  .filters-bar{background:var(--white);border-bottom:1px solid var(--gray-200);padding:16px 32px;
    display:flex;gap:16px;align-items:center;flex-wrap:wrap;box-shadow:var(--shadow-sm);}
  .filter-group{display:flex;align-items:center;gap:8px;}
  .filter-label{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--gray-500);white-space:nowrap;}
  .filter-group select{border:2px solid var(--gray-300);border-radius:var(--radius-sm);padding:7px 12px;
    font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;color:var(--gray-700);
    background:var(--white);cursor:pointer;transition:all .2s;min-width:140px;}
  .filter-group select:focus,.filter-group select:hover{border-color:var(--blue-main);outline:none;}
  .tab-group{display:flex;gap:4px;}
  .tab-btn{padding:7px 16px;border-radius:var(--radius-sm);border:2px solid var(--gray-300);
    background:var(--white);font-size:12px;font-weight:700;color:var(--gray-500);cursor:pointer;transition:all .2s;}
  .tab-btn.active{background:var(--blue-main);border-color:var(--blue-main);color:var(--white);box-shadow:0 4px 12px rgba(0,87,184,0.3);}
  .tab-btn:hover:not(.active){border-color:var(--blue-main);color:var(--blue-main);}
  .filter-sep{width:1px;height:32px;background:var(--gray-300);}

  /* CONTEXT BANNER */
  .context-banner{background:linear-gradient(90deg,var(--blue-light),#f0f7ff);
    border:1.5px solid var(--blue-main);border-radius:var(--radius-sm);
    padding:10px 20px;margin:20px 32px 0;display:flex;align-items:center;gap:10px;
    font-size:13px;font-weight:700;color:var(--blue-dark);}
  .context-banner span{color:var(--blue-main);font-weight:800;}

  /* MAIN */
  .main{padding:20px 32px 32px;max-width:1600px;margin:0 auto;}
  .section-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;margin-top:24px;}
  .section-tag{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:99px;
    font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;}
  .section-tag.blue{background:var(--blue-main);color:white;}
  .section-tag.orange{background:var(--orange);color:white;}
  .section-tag.teal{background:var(--teal);color:white;}
  .section-line{flex:1;height:2px;background:var(--gray-200);border-radius:2px;}

  /* BIG NUMBERS */
  .bn-row{display:grid;gap:12px;margin-bottom:12px;}
  .bn-row-2{grid-template-columns:1fr 1fr;}
  .bn-row-4{grid-template-columns:repeat(4,1fr);}
  .bn-card{background:var(--white);border-radius:var(--radius);padding:18px 20px;
    box-shadow:var(--shadow-sm);border:1px solid var(--gray-200);position:relative;overflow:hidden;
    transition:transform .2s,box-shadow .2s;}
  .bn-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);}
  .bn-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;border-radius:var(--radius) var(--radius) 0 0;}
  .bn-card.blue::before{background:var(--blue-main);}
  .bn-card.orange::before{background:var(--orange);}
  .bn-card.teal::before{background:var(--teal);}
  .bn-card.green::before{background:var(--green);}
  .bn-card.purple::before{background:#7C3AED;}
  .card-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
  .card-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
  .bn-card.blue .card-icon{background:var(--blue-light);}
  .bn-card.orange .card-icon{background:var(--orange-light);}
  .bn-card.teal .card-icon{background:var(--teal-light);}
  .bn-card.green .card-icon{background:var(--green-light);}
  .bn-card.purple .card-icon{background:#F3EEFF;}
  .card-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--gray-500);line-height:1.3;}
  .card-channel-tag{font-size:9px;font-weight:800;padding:2px 7px;border-radius:99px;margin-top:3px;display:inline-block;}
  .tag-site{background:var(--blue-light);color:var(--blue-main);}
  .tag-ifood{background:var(--teal-light);color:var(--teal);}
  .tag-geral{background:#F3EEFF;color:#7C3AED;}
  .card-values-row{display:flex;gap:16px;align-items:flex-end;flex-wrap:wrap;}
  .card-metric{flex:1;min-width:80px;}
  .card-metric-label{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--gray-400,#9FB3CC);margin-bottom:2px;}
  .card-value{font-family:'Sora',sans-serif;font-size:32px;font-weight:800;line-height:1;margin-bottom:2px;}
  .card-value.sm{font-size:24px;}
  .bn-card.blue .card-value{color:var(--blue-main);}
  .bn-card.orange .card-value{color:var(--orange);}
  .bn-card.teal .card-value{color:var(--teal);}
  .bn-card.green .card-value{color:var(--green);}
  .bn-card.purple .card-value{color:#7C3AED;}
  .card-sub{font-size:10px;color:var(--gray-500);font-weight:600;margin-bottom:6px;}
  .meta-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:99px;font-size:10px;font-weight:800;}
  .meta-badge.above{background:#DCFCE7;color:#16A34A;}
  .meta-badge.below{background:#FEE2E2;color:#DC2626;}
  .meta-badge.near{background:#FEF9C3;color:#CA8A04;}
  .card-total{font-size:10px;color:var(--gray-500);font-weight:600;margin-top:4px;}
  .card-divider{width:1px;background:var(--gray-200);align-self:stretch;margin:0 4px;}

  /* CHANNEL BLOCK: cards + gauges side by side */
  .channel-block{display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:8px;}
  .channel-cards{display:flex;flex-direction:column;gap:12px;}
  .channel-gauges{display:grid;grid-template-columns:1fr 1fr;gap:16px;}

  /* GAUGE SECTION */
  .gauge-section{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:12px;}
  .gauge-card{background:var(--white);border-radius:var(--radius);padding:24px 20px 18px;
    box-shadow:var(--shadow-sm);border:1px solid var(--gray-200);text-align:center;
    transition:transform .2s, box-shadow .2s;cursor:default;}
  .gauge-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-md);}
  .gauge-card-title{font-family:'Sora',sans-serif;font-size:13px;font-weight:800;
    color:var(--gray-700);margin-bottom:2px;letter-spacing:-.2px;}
  .gauge-card-sub{font-size:11px;color:var(--gray-500);font-weight:700;margin-bottom:14px;}
  .gauge-wrap{position:relative;width:220px;height:120px;margin:0 auto 4px;}
  .gauge-wrap svg{width:100%;height:100%;overflow:visible;}
  .gauge-stat-row{display:flex;justify-content:space-around;margin-top:14px;padding-top:14px;
    border-top:2px solid var(--gray-200);}
  .gauge-stat{text-align:center;padding:0 8px;}
  .gauge-stat-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--gray-500);}
  .gauge-stat-val{font-family:'Sora',sans-serif;font-size:18px;font-weight:800;color:var(--gray-700);margin-top:3px;}

  /* CHARTS */
  .charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
  .chart-card{background:var(--white);border-radius:var(--radius);padding:24px;
    box-shadow:var(--shadow-sm);border:1px solid var(--gray-200);}
  .chart-card-title{font-size:14px;font-weight:800;color:var(--gray-700);margin-bottom:16px;
    display:flex;align-items:center;justify-content:space-between;}
  .chart-badge{font-size:11px;padding:3px 10px;border-radius:99px;font-weight:700;}
  .chart-badge.blue{background:var(--blue-light);color:var(--blue-main);}
  .chart-badge.teal{background:var(--teal-light);color:var(--teal);}
  canvas{max-height:220px;}

  /* TABLES */
  .table-card{background:var(--white);border-radius:var(--radius);padding:24px;
    box-shadow:var(--shadow-sm);border:1px solid var(--gray-200);overflow:hidden;}
  .table-wrapper{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:13px;}
  thead tr{background:var(--blue-main);color:white;}
  thead th{padding:11px 14px;text-align:left;font-weight:800;font-size:11px;
    text-transform:uppercase;letter-spacing:.8px;white-space:nowrap;}
  tbody tr{border-bottom:1px solid var(--gray-200);transition:background .15s;}
  tbody tr:hover{background:var(--blue-light);}
  tbody td{padding:10px 14px;font-weight:600;color:var(--gray-700);}
  .pct-cell{display:flex;align-items:center;gap:8px;}
  .pct-bar{flex:1;height:6px;background:var(--gray-200);border-radius:99px;min-width:50px;}
  .pct-bar-fill{height:100%;border-radius:99px;}
  .pill{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:800;}
  .pill.green{background:var(--green-light);color:#16A34A;}
  .pill.red{background:var(--red-light);color:var(--red);}
  .pill.yellow{background:#FEF9C3;color:#A16207;}
  .empty-state{text-align:center;padding:40px;color:var(--gray-500);font-size:14px;font-weight:600;}
  .chart-card .chart-canvas-wrap{position:relative;height:250px;width:100%;}
  canvas{display:block;}

  .footer{text-align:center;padding:24px 32px;color:var(--gray-500);font-size:12px;
    font-weight:600;border-top:1px solid var(--gray-200);background:var(--white);margin-top:8px;}

  @media(max-width:1100px){
    .bignumbers-grid{grid-template-columns:repeat(2,1fr);}
    .charts-grid{grid-template-columns:1fr;}
    .thermo-row{grid-template-columns:1fr;}
  }
  @media(max-width:700px){
    .main{padding:16px;}
    .filters-bar{padding:12px 16px;}
    .bignumbers-grid{grid-template-columns:1fr 1fr;}
    .header{padding:0 16px;}
    .context-banner{margin:12px 16px 0;}
  }
</style>
</head>
<body>

<header class="header">
  <div class="header-logos">
    <img src="data:image/png;base64," alt="Grupo Amigão" />
    <div class="logo-divider"></div>
    <img src="data:image/png;base64," alt="Pedido Perfeito" style="height:64px;" />
  </div>
  <div class="header-title">
    <div class="label">📊 Painel Operacional</div>
    <h1>Dashboard — Pedido Perfeito</h1>
  </div>
  <div class="header-date" id="headerDate"></div>
</header>

<div class="filters-bar">
  <div class="filter-group">
    <span class="filter-label">📅 Período</span>
    <div class="tab-group">
      <button class="tab-btn active" id="tabSemana" onclick="switchPeriod('semana')">Por Semana</button>
      <button class="tab-btn" id="tabMes" onclick="switchPeriod('mes')">Por Mês</button>
    </div>
  </div>
  <div class="filter-sep"></div>
  <div class="filter-group">
    <span class="filter-label" id="periodLabel">🗓 Semana</span>
    <select id="filterPeriod" onchange="applyFilters()"></select>
  </div>
  <div class="filter-sep"></div>
  <div class="filter-group">
    <span class="filter-label">📦 Canal</span>
    <div class="tab-group">
      <button class="tab-btn active" id="tabAll" onclick="switchCanal('all')">Todos</button>
      <button class="tab-btn" id="tabSite" onclick="switchCanal('site')">🛒 Site 1P</button>
      <button class="tab-btn" id="tabIfood" onclick="switchCanal('ifood')">🛵 iFood 3P</button>
    </div>
  </div>
  <div class="filter-sep"></div>
  <div class="filter-group">
    <span class="filter-label">🏪 Lojas</span>
    <select id="filterLoja" onchange="applyFilters()">
      <option value="all">Todas as Lojas</option>
    </select>
  </div>
</div>

<div class="context-banner" id="contextBanner">
  📍 Visualizando: <span id="ctxPeriod">Todas as semanas</span> · Canal: <span id="ctxCanal">Todos</span> · Loja: <span id="ctxLoja">Todas</span>
</div>

<main class="main">

  <!-- ══ SITE 1P ══ -->
  <div class="section-header">
    <span class="section-tag blue">🛒 Site 1P — E-Commerce</span>
    <div class="section-line"></div>
  </div>
  <div class="channel-block">
    <!-- Cards 1P -->
    <div class="channel-cards">
      <div class="bn-card blue" id="card-site">
        <div class="card-header">
          <div class="card-icon">⭐</div>
          <div>
            <div class="card-label">Pedido Perfeito</div>
            <span class="card-channel-tag tag-site">Site 1P · Meta 85%</span>
          </div>
        </div>
        <div class="card-value" id="bn-pp-site">—</div>
        <span class="meta-badge" id="badge-pp-site">—</span>
        <div class="card-total" id="total-site">—</div>
      </div>
      <div class="bn-card orange" id="card-site-pc">
        <div class="card-header">
          <div class="card-icon">✅</div>
          <div>
            <div class="card-label">Pedido Completo</div>
            <span class="card-channel-tag tag-site">Site 1P · Meta 95%</span>
          </div>
        </div>
        <div class="card-value" id="bn-pc-site">—</div>
        <span class="meta-badge" id="badge-pc-site">—</span>
        <div class="card-total" id="total-site2">—</div>
      </div>
    </div>
    <!-- Gauges 1P — rendered by buildGaugeSVG() -->
    <div class="channel-gauges">
      <div class="gauge-card" id="gcard-gs1p-pp">
        <div class="gauge-card-title">⭐ Pedido Perfeito</div>
        <div class="gauge-card-sub" id="gsub-gs1p-pp">Meta: 85%</div>
        <div class="gauge-wrap" id="gwrap-gs1p-pp"></div>
        <div class="gauge-stat-row">
          <div class="gauge-stat">
            <div class="gauge-stat-label">Atual</div>
            <div class="gauge-stat-val" id="gs1p-pp-stat">—</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Meta</div>
            <div class="gauge-stat-val" style="color:#E53E3E">85%</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Diferença</div>
            <div class="gauge-stat-val" id="gs1p-pp-diff">—</div>
          </div>
        </div>
      </div>
      <div class="gauge-card" id="gcard-gs1p-pc">
        <div class="gauge-card-title">✅ Pedido Completo</div>
        <div class="gauge-card-sub" id="gsub-gs1p-pc">Meta: 95%</div>
        <div class="gauge-wrap" id="gwrap-gs1p-pc"></div>
        <div class="gauge-stat-row">
          <div class="gauge-stat">
            <div class="gauge-stat-label">Atual</div>
            <div class="gauge-stat-val" id="gs1p-pc-stat">—</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Meta</div>
            <div class="gauge-stat-val" style="color:#E53E3E">95%</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Diferença</div>
            <div class="gauge-stat-val" id="gs1p-pc-diff">—</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ IFOOD 3P ══ -->
  <div class="section-header" style="margin-top:24px;">
    <span class="section-tag teal">🛵 iFood 3P — Marketplace</span>
    <div class="section-line"></div>
  </div>
  <div class="channel-block">
    <!-- Cards 3P -->
    <div class="channel-cards">
      <div class="bn-card teal" id="card-ifood">
        <div class="card-header">
          <div class="card-icon">⭐</div>
          <div>
            <div class="card-label">Pedido Perfeito</div>
            <span class="card-channel-tag tag-ifood">iFood 3P · Meta 60%</span>
          </div>
        </div>
        <div class="card-value" id="bn-pp-ifood">—</div>
        <span class="meta-badge" id="badge-pp-ifood">—</span>
        <div class="card-total" id="total-ifood">—</div>
      </div>
      <div class="bn-card teal" id="card-ifood-pc">
        <div class="card-header">
          <div class="card-icon">✅</div>
          <div>
            <div class="card-label">Pedido Completo</div>
            <span class="card-channel-tag tag-ifood">iFood 3P · Meta 80%</span>
          </div>
        </div>
        <div class="card-value" id="bn-pc-ifood">—</div>
        <span class="meta-badge" id="badge-pc-ifood">—</span>
        <div class="card-total" id="total-ifood2">—</div>
      </div>
    </div>
    <!-- Gauges 3P — rendered by buildGaugeSVG() -->
    <div class="channel-gauges">
      <div class="gauge-card" id="gcard-gi3p-pp">
        <div class="gauge-card-title">⭐ Pedido Perfeito</div>
        <div class="gauge-card-sub" id="gsub-gi3p-pp">Meta: 60%</div>
        <div class="gauge-wrap" id="gwrap-gi3p-pp"></div>
        <div class="gauge-stat-row">
          <div class="gauge-stat">
            <div class="gauge-stat-label">Atual</div>
            <div class="gauge-stat-val" id="gi3p-pp-stat">—</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Meta</div>
            <div class="gauge-stat-val" style="color:#E53E3E">60%</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Diferença</div>
            <div class="gauge-stat-val" id="gi3p-pp-diff">—</div>
          </div>
        </div>
      </div>
      <div class="gauge-card" id="gcard-gi3p-pc">
        <div class="gauge-card-title">✅ Pedido Completo</div>
        <div class="gauge-card-sub" id="gsub-gi3p-pc">Meta: 80%</div>
        <div class="gauge-wrap" id="gwrap-gi3p-pc"></div>
        <div class="gauge-stat-row">
          <div class="gauge-stat">
            <div class="gauge-stat-label">Atual</div>
            <div class="gauge-stat-val" id="gi3p-pc-stat">—</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Meta</div>
            <div class="gauge-stat-val" style="color:#E53E3E">80%</div>
          </div>
          <div class="gauge-stat">
            <div class="gauge-stat-label">Diferença</div>
            <div class="gauge-stat-val" id="gi3p-pc-diff">—</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="section-header">
    <span class="section-tag blue">⭐ Pedido Perfeito — Evolução</span>
    <div class="section-line"></div>
    <span style="font-size:11px;color:var(--gray-500);font-weight:700;white-space:nowrap;">Meta: 85%</span>
  </div>
  <div class="charts-grid" style="margin-bottom:16px;">
    <div class="chart-card" id="chart-site-wrap">
      <div class="chart-card-title">
        <span>Site 1P — % Pedido Perfeito</span>
        <span class="chart-badge blue">🛒 E-Commerce</span>
      </div>
      <div class="chart-canvas-wrap"><canvas id="chart-site-pp"></canvas></div>
    </div>
    <div class="chart-card" id="chart-ifood-wrap">
      <div class="chart-card-title">
        <span>iFood 3P — % Pedido Perfeito</span>
        <span class="chart-badge teal">🛵 iFood</span>
      </div>
      <div class="chart-canvas-wrap"><canvas id="chart-ifood-pp"></canvas></div>
    </div>
  </div>

  <div class="section-header">
    <span class="section-tag orange">✅ Pedido Completo — Evolução</span>
    <div class="section-line"></div>
    <span style="font-size:11px;color:var(--gray-500);font-weight:700;white-space:nowrap;">Meta: 95%</span>
  </div>

  </tr>`;
}

function renderTableSite(lojaCode) {
  const tbody = document.getElementById('tbody-site');
  const periodLabel = state.periodoVal==='all'?'Todas as semanas':state.periodoVal;
  document.getElementById('badge-site-period').textContent = periodLabel;
  let rows = [...RAW.siteLojas];
  if (lojaCode) rows = rows.filter(r => r.codigo === lojaCode);
  rows.sort((a,b) => b.pctPP - a.pctPP);
  if (!rows.length) { tbody.innerHTML='<tr><td colspan="9" class="empty-state">Esta loja não possui dados de Site 1P</td></tr>'; return; }
  tbody.innerHTML = rows.map((r,i) => rowHtml(i, r.loja, r, 0.85, 0.95, getStatusSite)).join('');
}


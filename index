  document.getElementById('card-site-pc').style.display  = showS?'':'none';
  document.getElementById('card-ifood').style.display    = showI?'':'none';
  document.getElementById('card-ifood-pc').style.display = showI?'':'none';
  // Rebuild loja list filtered by canal, then apply
  populateLojaFilter();
  applyFilters();
}

// ══════════════════════════════════════════
//  CORE: APPLY FILTERS & COMPUTE
//  Loja filter drives aggregation for ALL
//  big numbers, thermometers, and charts.
// ══════════════════════════════════════════
function applyFilters() {
  state.periodoVal = document.getElementById('filterPeriod').value;
  state.loja       = document.getElementById('filterLoja').value;

  // state.loja is now a store CODE ('all' | '82' | '19' etc.)
  const lojaCode = state.loja === 'all' ? null : state.loja;

  // Find unified loja entry
  const lojaEntry = lojaCode
    ? RAW.lojasUnificadas.find(l => l.codigo === lojaCode)
    : null;

  const hasLojaCode = lojaCode !== null;
  const lojaHasSite  = lojaEntry ? lojaEntry.temSite  : true;
  const lojaHasIfood = lojaEntry ? lojaEntry.temIfood : true;

  // ── Period matcher ──
  const matchPeriod = d => {
    if (state.periodoVal === 'all') return true;
    if (state.period === 'semana') return d.semana === state.periodoVal;
    return d.mes === state.periodoVal;
  };

  const agg = rows => rows.reduce((a,b) =>
    ({pp:a.pp+b.pp, pc:a.pc+b.pc, inc:a.inc+b.inc, total:a.total+b.total}),
    {pp:0,pc:0,inc:0,total:0});

  const safe = (num, den) => den > 0 ? num / den : null;

  // ── Site aggregation ──
  // If a loja is selected and it has site data → filter to that loja
  // If a loja is selected but has NO site → no site data
  let siteAgg, filtSiteChart;
  if (hasLojaCode && !lojaHasSite) {
    siteAgg = {pp:0,pc:0,inc:0,total:0};
    filtSiteChart = [];
  } else if (hasLojaCode && lojaHasSite) {
    const lojaRows = RAW.siteLojas.filter(r => r.codigo === lojaCode);
    siteAgg = lojaRows.length
      ? {pp:lojaRows[0].pp, pc:lojaRows[0].pc, inc:lojaRows[0].inc, total:lojaRows[0].total}
      : {pp:0,pc:0,inc:0,total:0};
    filtSiteChart = RAW.siteSemanas.filter(matchPeriod);
  } else {
    siteAgg = agg(RAW.siteSemanas.filter(matchPeriod));
    filtSiteChart = RAW.siteSemanas.filter(matchPeriod);
  }

  // ── iFood aggregation ──
  let ifoodAgg, filtIfoodChart;
  if (hasLojaCode && !lojaHasIfood) {
    ifoodAgg = {pp:0,pc:0,inc:0,total:0};
    filtIfoodChart = [];
  } else if (hasLojaCode && lojaHasIfood) {
    const lojaRows = RAW.ifoodLojas.filter(r => r.codigo === lojaCode);
    ifoodAgg = lojaRows.length
      ? {pp:lojaRows[0].pp, pc:lojaRows[0].pc, inc:lojaRows[0].inc, total:lojaRows[0].total}
      : {pp:0,pc:0,inc:0,total:0};
    filtIfoodChart = RAW.ifoodSemanas.filter(matchPeriod);
  } else {
    ifoodAgg = agg(RAW.ifoodSemanas.filter(matchPeriod));
    filtIfoodChart = RAW.ifoodSemanas.filter(matchPeriod);
  }

  // ── Canal visibility ──
  const showS = state.canal !== 'ifood';
  const showI = state.canal !== 'site';

  const ppSite  = showS ? safe(siteAgg.pp,  siteAgg.total)  : null;
  const pcSite  = showS ? safe(siteAgg.pp  + siteAgg.pc,  siteAgg.total)  : null;
  const ppIfood = showI ? safe(ifoodAgg.pp, ifoodAgg.total) : null;
  const pcIfood = showI ? safe(ifoodAgg.pp + ifoodAgg.pc, ifoodAgg.total) : null;

  // ── Update Big Numbers ──
  setBN('bn-pp-site',  'badge-pp-site',  ppSite,  0.85);
  setBN('bn-pc-site',  'badge-pc-site',  pcSite,  0.95);
  setBN('bn-pp-ifood', 'badge-pp-ifood', ppIfood, 0.60);
  setBN('bn-pc-ifood', 'badge-pc-ifood', pcIfood, 0.80);

  const fmtPed = n => n > 0 ? `📦 ${n.toLocaleString('pt-BR')} pedidos` : '';
  document.getElementById('total-site').textContent     = fmtPed(siteAgg.total);
  document.getElementById('total-site2').textContent    = fmtPed(siteAgg.total);
  document.getElementById('total-ifood').textContent    = fmtPed(ifoodAgg.total);
  document.getElementById('total-ifood2').textContent   = fmtPed(ifoodAgg.total);

  // ── Update 4 Gauges ──
  updateGauge('gs1p-pp', ppSite,  0.85);
  updateGauge('gs1p-pc', pcSite,  0.95);
  updateGauge('gi3p-pp', ppIfood, 0.60);
  updateGauge('gi3p-pc', pcIfood, 0.80);

  // ── Update Charts ──
  updateCharts(filtSiteChart, filtIfoodChart);

  // ── Update Tables ──
  renderTableSite(lojaCode);
  renderTableIfood(lojaCode);

  // ── Context banner ──
  const periodoLabel = state.periodoVal === 'all'
    ? (state.period === 'semana' ? 'Todas as semanas' : 'Todos os meses')
    : state.periodoVal === '04' ? 'Abril' : state.periodoVal === '05' ? 'Maio' : state.periodoVal;
  const canalLabel = state.canal==='all'?'Todos':state.canal==='site'?'🛒 Site 1P':'🛵 iFood 3P';
  const lojaLabel  = lojaEntry ? `${lojaEntry.nome} (${[lojaEntry.temSite?'1P':'',lojaEntry.temIfood?'3P':''].filter(Boolean).join(' + ')})` : 'Todas';
  document.getElementById('ctxPeriod').textContent = periodoLabel;
  document.getElementById('ctxCanal').textContent  = canalLabel;
  document.getElementById('ctxLoja').textContent   = lojaLabel;
}


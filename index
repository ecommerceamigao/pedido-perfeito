function goalPlugin(metaVal, label, color) {
  return {
    id: 'goal_' + metaVal,
    afterDraw(chart) {
      const {ctx, chartArea, scales} = chart;
      if (!chartArea) return;
      const y = scales.y.getPixelForValue(metaVal);
      ctx.save();
      ctx.setLineDash([6, 4]);
      ctx.strokeStyle = color || '#E53E3E';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(chartArea.left, y);
      ctx.lineTo(chartArea.right, y);
      ctx.stroke();
      ctx.fillStyle = color || '#E53E3E';
      ctx.font = 'bold 11px Nunito';
      ctx.fillText(label, chartArea.right - 72, y - 6);
      ctx.restore();
    }
  };
}

function makeChartOpts(yMin) {
  return {
    responsive: true,
    maintainAspectRatio: false,
    interaction: { mode: 'index', intersect: false },
    plugins: {
      legend: {
        display: true,
        position: 'top',
        align: 'end',
        labels: { boxWidth: 12, boxHeight: 12, borderRadius: 4, font: { size: 11, weight: '700', family: 'Nunito' }, padding: 12 }
      },
      tooltip: { callbacks: { label: c => ` ${c.dataset.label}: ${c.parsed.y !== null ? c.parsed.y.toFixed(1)+'%' : '—'}` } }
    },
    scales: {
      y: {
        min: yMin || 0,
        max: 101,
        ticks: { callback: v => v > 100 ? '' : v+'%', font: {size:11}, stepSize: 10 },
        grid: { color: '#EDF1F7' },
        clip: true,
      },
      x: { ticks: { font: {size:11} }, grid: { display: false } }
    },
    layout: { clip: true }
  };
}

const COLORS = {
  blue:   { solid: '#0057B8', fill: 'rgba(0,87,184,0.10)' },
  teal:   { solid: '#009CA6', fill: 'rgba(0,156,166,0.10)' },
  orange: { solid: '#F5821F', fill: 'rgba(245,130,31,0.10)' },
  green:  { solid: '#00B47E', fill: 'rgba(0,180,126,0.10)' },
};

function makeDS(label, colorKey) {
  const c = COLORS[colorKey];
  return {
    label,
    data: [],
    borderColor: c.solid,
    backgroundColor: c.fill,
    borderWidth: 2.5,
    pointRadius: 5,
    pointHoverRadius: 7,
    pointBackgroundColor: c.solid,
    pointBorderColor: '#fff',
    pointBorderWidth: 2,
    tension: 0.35,
    fill: false,
    spanGaps: true,
    clip: true,
  };
}

function gradientFillPlugin(r, g, b) {
  return {
    id: 'gradFill_' + r + g + b,
    beforeDatasetsDraw(chart) {
      const { ctx, chartArea, scales } = chart;
      if (!chartArea) return;
      const meta = chart.getDatasetMeta(0);
      if (!meta || !meta.data || !meta.data.length) return;
      const { top, bottom, left, right } = chartArea;
      ctx.save();
      ctx.beginPath();
      ctx.rect(left, top, right - left, bottom - top);
      ctx.clip();
      const grad = ctx.createLinearGradient(0, top, 0, bottom);
      grad.addColorStop(0, `rgba(${r},${g},${b},0.18)`);
      grad.addColorStop(1, `rgba(${r},${g},${b},0.02)`);
      ctx.beginPath();
      const pts = meta.data;
      ctx.moveTo(pts[0].x, bottom);
      pts.forEach(pt => ctx.lineTo(pt.x, Math.min(pt.y, bottom)));
      ctx.lineTo(pts[pts.length - 1].x, bottom);
      ctx.closePath();
      ctx.fillStyle = grad;
      ctx.fill();
      ctx.restore();
    }
  };
}


function updateCharts(filtSite, filtIfood) {
  // ── Group by period label (semana or mes) ──
  const groupBy = (rows, keyFn, ppFn, pcFn) => {
    const map = new Map();
    rows.forEach(d => {
      const k = keyFn(d);
      if (!map.has(k)) map.set(k, {pp:0,pc:0,total:0});
      const e = map.get(k);
      e.pp += d.pp; e.pc += d.pc; e.total += d.total;
    });
    return [...map.entries()].map(([k,v]) => ({
      label: k,
      pctPP: v.total > 0 ? +(v.pp/v.total*100).toFixed(2) : null,
      pctPC: v.total > 0 ? +((v.pp+v.pc)/v.total*100).toFixed(2) : null,
    }));
  };

  const keyFn = state.period === 'mes' ? d => (d.mes==='04'?'Abril':'Maio') : d => d.semana;

  const sgSite  = groupBy(filtSite,  keyFn);
  const sgIfood = groupBy(filtIfood, keyFn);

  const setChart = (chart, groups, field) => {
    chart.data.labels = groups.map(g => g.label);
    chart.data.datasets[0].data = groups.map(g => g[field]);
    chart.update('active');
  };

  setChart(chartSitePP,  sgSite,  'pctPP');
  setChart(chartIfoodPP, sgIfood, 'pctPP');
  setChart(chartSitePC,  sgSite,  'pctPC');
  setChart(chartIfoodPC, sgIfood, 'pctPC');
}


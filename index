function switchPeriod(p) {
  state.period = p;
  document.getElementById('tabSemana').classList.toggle('active', p==='semana');
  document.getElementById('tabMes').classList.toggle('active', p==='mes');
  populatePeriodFilter();
  applyFilters();
}


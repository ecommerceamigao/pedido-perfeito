// ══════════════════════════════════════════
function populatePeriodFilter() {
  const sel = document.getElementById('filterPeriod');
  const lbl = document.getElementById('periodLabel');
  sel.innerHTML = '';
  if (state.period === 'semana') {
    lbl.textContent = '🗓 Semana';
    const semanasS = [...new Set(RAW.siteSemanas.map(d=>d.semana))];
    const semanasI = [...new Set(RAW.ifoodSemanas.map(d=>d.semana))];
    const all = [...new Set([...semanasS,...semanasI])].sort();
    sel.innerHTML = '<option value="all">Todas as Semanas</option>';
    all.forEach(s => sel.innerHTML += `<option value="${s}">${s}</option>`);
  } else {
    lbl.textContent = '🗓 Mês';
    sel.innerHTML = '<option value="all">Todos os Meses</option><option value="04">Abril</option><option value="05">Maio</option>';
  }
  state.periodoVal = 'all';
  sel.value = 'all';
}

function populateLojaFilter() {
  const sel = document.getElementById('filterLoja');
  sel.innerHTML = '<option value="all">Todas as Lojas</option>';

  // Filter unified list by canal
  const lojas = RAW.lojasUnificadas.filter(l => {
    if (state.canal === 'site')  return l.temSite;
    if (state.canal === 'ifood') return l.temIfood;
    return true; // 'all' — show everything
  });

  lojas.forEach(l => {
    const tags = [];
    if (l.temSite)  tags.push('1P');
    if (l.temIfood) tags.push('3P');
    const label = `${l.nome} (${tags.join(' + ')})`;
    sel.innerHTML += `<option value="${l.codigo}">${label}</option>`;
  });

  sel.value = 'all';
  state.loja = 'all';
}

